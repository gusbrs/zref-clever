\documentclass{book}

\input{regression-test}

\ExplSyntaxOn
\debug_on:n { check-declarations , deprecation }
\ExplSyntaxOff

\newcommand{\testtmp}{}
\ExplSyntaxOn
\cs_new_protected:Npn \my_tl_show_if_exist:n #1
  { \tl_if_exist:cT {#1} { \tl_show:c {#1} } }
\NewDocumentCommand{\myshowaux}{m}{ \my_tl_show_if_exist:n { Z@R@ #1} }
\ExplSyntaxOff

% FIXME I would have liked to use "french" here, to test things with an active
% colon.  It's supposed to be working.  But something in `l3build' is not
% liking this.  For some reason, when testing for engines other than pdftex,
% l3build appears to reuse the .aux file (I think...), and messes up catcodes
% resulting in the file reaching TeX's limit of 100 errors, thus leaving and
% not writing a new .aux file, repeating the process on the next run.
\usepackage[english]{babel}

\usepackage{zref-clever}
\usepackage{zref-check}
\usepackage{zref-titleref}

\usepackage{hyperref}

% This file is intended to test the fancylabel and related options.

\begin{document}

\textsuperscript{avoid font warning}

% Just a bogus counter which will not interact with any of the types of
% interest.
\newcounter{myfoobarcounter}
\refstepcounter{myfoobarcounter}

\START

\BEGINTEST{Option: fancylabel=...}
\zcsetup{fancylabel}
\label{chap:foo-1-1}
\label{foo-1-2}
\label{cha:foo-1-3}
\label{sec:foo-1-4}
\zcsetup{fancylabel=false}
\label{chap:foo-1-5}
\label{sec:foo-1-6}
\myshowaux{chap:foo-1-1}
\myshowaux{foo-1-2}
\myshowaux{cha:foo-1-3}
\myshowaux{sec:foo-1-4}
\myshowaux{chap:foo-1-5}
\myshowaux{sec:foo-1-6}
\ENDTEST

% Enable it globally for remaining tests.
\zcsetup{fancylabel=true}

\BEGINTEST{Option: fancydelim=...}
\zcsetup{fancydelim={::}}
\label{chap::foo-2-1}
\label{chap:foo-2-2}
\zcsetup{fancydelim={<!bar!>}}
\label{chap<!bar!>foo-2-3}
\label{sec:foo-2-4}
\myshowaux{chap::foo-2-1}
\myshowaux{chap:foo-2-2}
\myshowaux{chap<!bar!>foo-2-3}
\myshowaux{sec:foo-2-4}
\ENDTEST

\BEGINTEST{Option: fancyprefix=...}
% initial value
\label{chap:foo-3-1}
\label{sec:foo-3-2}
\label{eq:foo-3-3}
\label{fig:foo-3-4}
\label{tab:foo-3-5}
\label{enum:foo-3-6}
\label{fn:foo-3-7}
% some which do not exist
\label{thm:foo-3-8}
\label{cha:foo-3-9}
% but now we create them
\zcsetup{fancyprefix={thm=theorem,cha=chapter}}
\label{thm:foo-3-10}
\label{cha:foo-3-11}
% remove some of the initial ones
\zcsetup{fancyprefix={chap=,sec=}}
\label{chap:foo-3-12}
\label{sec:foo-3-13}
\myshowaux{chap:foo-3-1}
\myshowaux{sec:foo-3-2}
\myshowaux{eq:foo-3-3}
\myshowaux{fig:foo-3-4}
\myshowaux{tab:foo-3-5}
\myshowaux{enum:foo-3-6}
\myshowaux{fn:foo-3-7}
\myshowaux{thm:foo-3-8}
\myshowaux{cha:foo-3-9}
\myshowaux{thm:foo-3-10}
\myshowaux{cha:foo-3-11}
\myshowaux{chap:foo-3-12}
\myshowaux{sec:foo-3-13}
\ENDTEST

\BEGINTEST{Options interactions}
\begingroup
\zcsetup{fancylabel=false,countertype={myfoobarcounter=myfoobartype}}
\label{chap:foo-4-1}
\endgroup
\begingroup
\zcsetup{fancylabel=true,countertype={myfoobarcounter=myfoobartype}}
\label{chap:foo-4-2}
\endgroup
\begingroup
\zcsetup{reftype=mybarbaztype}
\label{chap:foo-4-3}
\endgroup
\myshowaux{chap:foo-4-1}
\myshowaux{chap:foo-4-2}
\myshowaux{chap:foo-4-3}
\ENDTEST

\OMIT

\end{document}
